{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge_pack",
  "type": "object",
  "required": [
    "pack_id",
    "skill_id",
    "title_zh",
    "title_en",
    "summary_zh",
    "summary_en",
    "concepts",
    "frameworks",
    "checklists",
    "templates",
    "source_ids"
  ],
  "properties": {
    "pack_id": { "type": "string" },
    "skill_id": { "type": "string" },
    "title_zh": { "type": "string" },
    "title_en": { "type": "string" },
    "summary_zh": { "type": "string" },
    "summary_en": { "type": "string" },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "frameworks": { "type": "array", "items": { "type": "object" } },
    "checklists": { "type": "array", "items": { "type": "string" } },
    "templates": { "type": "array", "items": { "type": "string" } },
    "situations": { "type": "array", "items": { "type": "string" } },
    "workflow_steps": { "type": "array", "items": { "type": "string" } },
    "decision_rules": { "type": "array", "items": { "type": "string" } },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "pitfalls": { "type": "array", "items": { "type": "string" } },
    "example_prompts": { "type": "array", "items": { "type": "string" } },
    "corpus_snapshot": { "type": "object" },
    "source_ids": { "type": "array", "items": { "type": "string" } }
  }
}
